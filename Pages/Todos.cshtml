@page "/todos"
@model WebApplication1.Pages.TodosModel

<h1>Todo List</h1>

<!-- 追加フォーム（Flask: <form action="/add" method="post">） -->
<form method="post" asp-page-handler="Add" style="margin-bottom:20px">
    <input type="text" name="title" placeholder="New todo..." required />
    <button type="submit">Add</button>
</form>

<!-- 一覧テーブル -->
<table border="1" cellpadding="8" cellspacing="0">
    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Done</th>
        <th>Action</th>
    </tr>
    @foreach (var todo in Model.Todos)
    {
        <tr>
            <td>@todo.Id</td>
            <td>@todo.Title</td>
            <td>@(todo.IsDone ? "Done" : "-")</td>
            <td>
                <!-- 完了/未完了トグル -->
                <form method="post" asp-page-handler="Toggle" style="display:inline">
                    <input type="hidden" name="id" value="@todo.Id" />
                    <button type="submit">@(todo.IsDone ? "Undo" : "Done")</button>
                </form>
                <!-- 削除 -->
                <form method="post" asp-page-handler="Delete" style="display:inline">
                    <input type="hidden" name="id" value="@todo.Id" />
                    <button type="submit" onclick="return confirm('Delete?')">Delete</button>
                </form>
            </td>
        </tr>
    }
</table>

<p>Total: @Model.Todos.Count</p>
